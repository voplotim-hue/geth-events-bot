# Telegram
TELEGRAM_BOT_TOKEN=123456:replace_me
ADMIN_USER_IDS=123456789,987654321
GROUP_CHAT_ID=-1001234567890
SUPERADMIN_USER_ID=123456789
BIRTHDAY_APPROVER_CHAT_ID=123456789

# Local calendar/time settings
TIMEZONE=Europe/Minsk
BIRTHDAY_CHECK_TIME=09:00
SEND_BIRTHDAYS_TO_GROUP=true
EVENT_DEFAULT_OPTIONS=Еду|Не еду|Пока не знаю

# Google Sheets through Google Sheets API.
# Leave disabled if you use the easier Apps Script mode below.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=replace_me

# Optional: download a service account JSON key and point to it.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json

# Alternative to GOOGLE_SERVICE_ACCOUNT_KEY_FILE:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=replace_me@replace_me.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n"

GOOGLE_SHEET_USERS=Users
GOOGLE_SHEET_EVENTS=Events
GOOGLE_SHEET_REGISTRATIONS=Registrations
GOOGLE_SHEET_EVENT_ROSTER=EventRoster
GOOGLE_SHEET_BIRTHDAY_LOG=BirthdayLog
GOOGLE_SHEET_BIRTHDAY_TEMPLATES=BirthdayTemplates

# Recommended simple mode without Google Cloud/service account:
# deploy google-apps-script/Code.gs as a Web App from inside the Google Sheet.
GOOGLE_APPS_SCRIPT_ENABLED=true
GOOGLE_APPS_SCRIPT_URL=
GOOGLE_APPS_SCRIPT_SECRET=replace_with_long_random_secret

# Legacy Excel in Microsoft 365 / OneDrive / SharePoint through Microsoft Graph
EXCEL_ENABLED=false
EXCEL_TENANT_ID=replace_me
EXCEL_CLIENT_ID=replace_me
EXCEL_CLIENT_SECRET=replace_me
EXCEL_DRIVE_ID=replace_me

# Use either EXCEL_ITEM_ID or EXCEL_WORKBOOK_PATH.
# EXCEL_ITEM_ID is more reliable after the workbook is uploaded.
EXCEL_ITEM_ID=replace_me
# EXCEL_WORKBOOK_PATH=TelegramEventsBot.xlsx

EXCEL_TABLE_USERS=Users
EXCEL_TABLE_EVENTS=Events
EXCEL_TABLE_REGISTRATIONS=Registrations
EXCEL_TABLE_EVENT_ROSTER=EventRoster
EXCEL_TABLE_BIRTHDAY_LOG=BirthdayLog
EXCEL_TABLE_BIRTHDAY_TEMPLATES=BirthdayTemplates
